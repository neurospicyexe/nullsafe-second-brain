# nullsafe-second-brain — environment schema (VPS MCP server, port 3001)
# @defaultSensitive=true @defaultRequired=false
#
# Only HALSETH_URL + HALSETH_SECRET are required. Everything else is an optional
# tuning knob with a code default. NOTE: CouchDB credentials, the embedding
# provider, the vault path, and the HTTP port live in `second-brain.config.json`
# — NOT here. HOME / USERPROFILE are OS-provided, listed only for completeness.

# --- Required ---

# Halseth Worker endpoint (e.g. https://halseth.<account>.workers.dev).
# @type=url @sensitive=false @required
HALSETH_URL=

# Halseth ADMIN_SECRET (named HALSETH_SECRET here) for authenticated calls.
# @type=string @sensitive @required
HALSETH_SECRET=

# --- Secrets ---

# DeepSeek V3 — synthesis / processing.
# @type=string @sensitive
DEEPSEEK_API_KEY=

# Bearer token for POST /ingest/discord fire-and-forget live ingestion.
# @type=string @sensitive
SB_INGEST_KEY=

# --- Models ---

# @type=string @sensitive=false
DEEPSEEK_MODEL=

# --- Cron schedules (node-cron strings; all have defaults) ---

# @type=string @sensitive=false
INGESTION_CRON=

# @type=string @sensitive=false
EVALUATOR_CRON=

# @type=string @sensitive=false
SIT_PROMPT_CRON=

# @type=string @sensitive=false
PATTERN_SYNTH_CRON=

# @type=string @sensitive=false
PERSONA_FEEDER_CRON=

# @type=string @sensitive=false
CORPUS_CRON=

# @type=string @sensitive=false
VAULT_MATERIALIZER_CRON=

# @type=string @sensitive=false
THOUGHTFORM_CRON=

# @type=string @sensitive=false
INBOX_FILER_CRON=

# --- Ingestion tuning ---

# @type=number @sensitive=false
INGESTION_CONCURRENCY=

# @type=number @sensitive=false
INGESTION_DELAY_MS=

# @type=number @sensitive=false
EMBEDDING_BATCH_SIZE=

# Directory path for corpus file intake (optional).
# @type=string @sensitive=false
CORPUS_INTAKE_DIR=

# --- Inbox auto-filer ---

# @type=boolean @sensitive=false
INBOX_FILER=

# @type=enum(hybrid,auto,suggest) @sensitive=false
INBOX_FILER_MODE=

# Confidence threshold (0-1) for auto-filing. Default 0.75.
# @type=number @sensitive=false
INBOX_FILER_CONFIDENCE=

# --- Drift evaluator (per-companion z-score calibration) ---

# @type=number @sensitive=false
DRIFT_PRESSURE_Z=

# @type=number @sensitive=false
DRIFT_GROWTH_Z=

# @type=number @sensitive=false
DRIFT_MIN_STD=

# @type=number @sensitive=false
DRIFT_MIN_MARGIN=

# @type=number @sensitive=false
DRIFT_MIN_SAMPLES=

# Cosine ceiling for entry collapse. Default 0.90.
# @type=number @sensitive=false
DRIFT_COLLAPSE_CEILING=

# @type=number @sensitive=false
DRIFT_BLOCKS_LIMIT=

# History window (days) for drift baseline. Default 30.
# @type=number @sensitive=false
DRIFT_HISTORY_LIMIT=

# --- Discord live ingestion / surprisal gate ---

# Gate enabling Discord live ingestion (bots check this).
# @type=boolean @sensitive=false
SB_LIVE_INGEST=

# Enable surprisal filtering on Discord ingestion. Default true.
# @type=boolean @sensitive=false
SB_SURPRISAL_GATE=

# Cosine similarity threshold for surprisal gate. Default 0.90.
# @type=number @sensitive=false
SB_SURPRISAL_THRESHOLD=

# Additive boost to valence-matched retrieval. Default 0.08.
# @type=number @sensitive=false
SB_RESONANCE_WEIGHT=
